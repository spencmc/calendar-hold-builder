# CalBot — Slack Bot Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to GitHub

# Slack tokens (from api.slack.com → your app → OAuth & Permissions / Basic Information)
SLACK_BOT_TOKEN=xoxb-your-bot-token-here
SLACK_APP_TOKEN=xapp-your-app-token-here

# G2 LiteLLM proxy (for AI-powered brief parsing)
LITELLM_PROXY_URL=https://llmproxy.g2.com
LITELLM_API_KEY=your-litellm-key-here

# Optional: link back to your Streamlit app in bot responses
STREAMLIT_APP_URL=https://your-app.streamlit.app
